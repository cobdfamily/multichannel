# Copy to .env and fill in. .env is gitignored.

# --- core ---
MC_DATABASE_URL=postgresql+asyncpg://multichannel:multichannel@localhost:5432/multichannel
MC_REDIS_URL=redis://localhost:6379/0
MC_BIND=0.0.0.0:8004
MC_LOG_LEVEL=INFO

# --- downstream services ---
MC_NOTAIO_URL=http://notaio:8003
MC_NOTAIO_CLIENT_SECRET=replace_me
MC_MEDICI_URL=http://medici:8002
MC_MEDICI_CLIENT_SECRET=replace_me

# --- provider credentials ---
# Postmark
MC_POSTMARK_SERVER_TOKEN=replace_me
MC_POSTMARK_WEBHOOK_SECRET=replace_me

# SignalWire (used by both the main service for outbound REST
# and the signalwire-relay sidecar for inbound WebSocket).
MC_SIGNALWIRE_PROJECT_ID=replace_me
MC_SIGNALWIRE_API_TOKEN=replace_me
MC_SIGNALWIRE_SPACE_URL=example.signalwire.com
MC_SIGNALWIRE_SIDECAR_HMAC=replace_me  # shared with the sidecar

# Meta Graph (Facebook Messenger + Instagram Direct)
MC_META_APP_SECRET=replace_me
MC_META_VERIFY_TOKEN=replace_me   # the value Meta echoes back during webhook setup
MC_META_PAGE_TOKEN=replace_me
MC_META_IG_USER_ID=replace_me
